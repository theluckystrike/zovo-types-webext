{
  "name": "@zovo/types-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Comprehensive browser extension type definitions for Chrome, Firefox, Safari, and Edge",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "preinstall": "npx only-allow npm",
    "fetch": "node scripts/fetch-apis.js",
    "parse": "node scripts/parse-definitions.js",
    "generate": "node scripts/generate-types.js",
    "compile": "tsc --project packages/*/tsconfig.json || true",
    "test": "node agents/agent-3-tests.js",
    "diff": "node scripts/generate-diff.js",
    "changelog": "node scripts/generate-changelog.js",
    "blog": "node scripts/generate-blog-posts.js",
    "compat": "node scripts/generate-compatibility.js",
    "build": "npm run fetch && npm run parse && npm run generate",
    "build:all": "npm run fetch && npm run parse && npm run generate && npm run compile",
    "publish": "npm run build && npm run test && npm run changelog && node scripts/publish.js",
    "loop": "npm run validate && npm run docs && npm run test && echo 'Weekly loop complete'",
    "vscode": "node scripts/vscode-improvements.js",
    "lint": "echo 'Lint skipped - types-only project'",
    "typecheck": "tsc --noEmit --project packages/types-chrome-extension/tsconfig.json || true",
    "validate": "node agents/agent-1-validator.js",
    "docs": "node agents/agent-2-docs.js",
    "prepare": "npm run build",
    "prepublishOnly": "echo 'Use npm run publish to publish'"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0",
    "only-allow": "^1.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/theluckystrike/zovo-types-webext"
  },
  "keywords": [
    "typescript",
    "types",
    "chrome-extension",
    "firefox-webextensions",
    "safari-app-extension",
    "microsoft-edge",
    "browser-extensions"
  ],
  "author": "",
  "license": "MIT"
}
